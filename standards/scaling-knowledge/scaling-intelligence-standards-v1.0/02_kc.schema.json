{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scaling-intelligence.org/schemas/kc.schema.json",
  "title": "Scaling Intelligence Knowledge Card",
  "description": "Validation schema for the YAML frontmatter of a Knowledge Card (node_type: knowledge-card), Knowledge Standard v1.0.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id", "schema_version", "title", "node_type", "layer", "status",
    "card_version", "created", "updated", "curator", "source_type",
    "source_confidence", "authors", "source_locator", "capabilities",
    "stages", "evidence_types"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^KC-[0-9]{4,5}$",
      "description": "Immutable node ID, never reused or renumbered."
    },
    "schema_version": { "type": "string", "const": "1.0" },
    "title": { "type": "string", "minLength": 3 },
    "node_type": { "type": "string", "const": "knowledge-card" },
    "layer": { "type": "string", "const": "A" },
    "status": {
      "type": "string",
      "enum": ["draft", "in-review", "accepted", "needs-refresh", "deprecated", "superseded"]
    },
    "card_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "curator": { "type": "string", "minLength": 1 },
    "source_type": {
      "type": "string",
      "enum": [
        "peer-reviewed", "grey-literature", "framework-or-methodology",
        "case-study", "tool-or-template", "evaluation-or-review", "dataset",
        "expert-input", "internal-document", "presentation",
        "workshop-output", "unpublished"
      ]
    },
    "source_confidence": {
      "type": "string",
      "enum": ["authoritative", "established", "provisional", "informal", "unverified"]
    },
    "authors": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "publication_year": { "type": ["integer", "null"], "minimum": 1900, "maximum": 2100 },
    "publisher": { "type": "string" },
    "source_locator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["archived_path", "access_date", "integrity_hash"],
      "properties": {
        "url": { "type": "string" },
        "doi": { "type": "string" },
        "archived_path": { "type": "string", "pattern": "^/sources/KC-[0-9]{4,5}__" },
        "access_date": { "type": "string", "format": "date" },
        "integrity_hash": { "type": "string", "pattern": "^sha256:" }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "innovation-characterization", "scaling-readiness", "scaling-strategy",
          "business-models", "delivery-systems", "last-mile-delivery",
          "partnerships", "institutionalization", "finance-readiness",
          "policy-engagement", "coaching", "stage-gating", "portfolio-management",
          "adaptive-learning", "knowledge-management", "monitoring-and-learning",
          "evidence-synthesis", "responsible-scaling", "gender-and-social-inclusion"
        ]
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["proof-of-concept", "transition-to-scale", "scaling", "cross-stage"]
      }
    },
    "methodology_family": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "ipsr", "scaling-scan", "aiccra-scaling-framework", "genderup",
          "responsible-scaling", "kohl-systems-approach", "paass",
          "link-methodology", "general", "none"
        ]
      }
    },
    "evidence_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "conceptual-argument", "methodological-design", "expert-judgment",
          "participant-self-assessment", "monitoring-data",
          "independently-validated-outcome", "comparative-evidence",
          "portfolio-level-evidence"
        ]
      }
    },
    "geography": { "type": "array", "items": { "type": "string" } },
    "sector": { "type": "array", "items": { "type": "string" } },
    "aow": {
      "type": "array",
      "items": { "type": "string", "enum": ["aow1", "aow2", "aow3", "aow4"] }
    },
    "tags": { "type": "array", "items": { "type": "string" } },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target", "type"],
        "properties": {
          "target": { "type": "string", "pattern": "^[A-Z]{2,3}-[0-9]{4,5}$" },
          "type": {
            "type": "string",
            "enum": [
              "derived_from", "describes", "supports", "contradicts", "refines",
              "relates_to", "part_of", "supersedes", "superseded_by", "cites",
              "applies_to_capability", "applies_to_stage",
              "authored_by", "affiliated_with", "works_on", "operates_in",
              "funded_by", "partners_with", "deploys", "part_of_package"
            ]
          },
          "note": { "type": "string" },
          "register": { "type": "string", "enum": ["observed", "interpretation"] }
        }
      }
    },
    "supersedes": { "type": "string" },
    "superseded_by": { "type": "string" },
    "review_due": { "type": "string", "format": "date" },
    "ai": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "machine_summary": { "type": "string" },
        "semantic_tags": { "type": "array", "items": { "type": "string" } },
        "embedding_status": { "type": "string", "enum": ["none", "pending", "embedded", "stale"] },
        "embedding_model": { "type": "string" },
        "vector_id": { "type": "string" },
        "graph_synced": { "type": "boolean" },
        "last_ai_processed": { "type": "string" }
      }
    }
  }
}
